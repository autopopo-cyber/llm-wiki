+    async def _handle_message_with_agent_plan_tree(
+        self, event, source, _quick_key: str, run_generation: int
+    ):
+        """
+        Plan-tree 调度分支：先分解任务，再逐节点执行。
+
+        当配置中 enable_plan_tree=True 时被调用。
+        """
+        from plan_tree import PlanTreeStore
+
+        session_entry = self.session_store.get_or_create_session(source)
