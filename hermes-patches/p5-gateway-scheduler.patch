+def _extract_plan_nodes(text: str) -> list:
+    """
+    从模型响应中提取计划节点。
+
+    期望格式：
+        [PLAN]
+        1. goal text | priority:high | context:extra info
+        2. another goal | priority:medium
+        [/PLAN]
+    """
+    import re
+    nodes = []
+    match = re.search(r"\[PLAN\](.*?)\[/PLAN\]", text, re.DOTALL | re.IGNORECASE)
+    if not match:
+        # 无标签时，将整个文本作为单一节点
+        return [{"goal": text.strip(), "context": "", "priority": 0}]
+
+    plan_body = match.group(1)
+    for line in plan_body.strip().splitlines():
+        line = line.strip()
+        if not line or line.startswith("-"):
+            continue
+        # 去掉前缀编号
+        line = re.sub(r"^\d+[\.\)\-]\s*", "", line)
+        if not line:
+            continue
+        goal = line
+        priority = 0
+        context = ""
+        if "|" in line:
+            parts = [p.strip() for p in line.split("|")]
+            goal = parts[0]
+            for p in parts[1:]:
+                if p.lower().startswith("priority:"):
+                    lvl = p.split(":", 1)[1].strip().lower()
+                    priority = {"high": 2, "medium": 1}.get(lvl, 0)
+                elif p.lower().startswith("context:"):
+                    context = p.split(":", 1)[1].strip()
+        nodes.append({"goal": goal, "context": context, "priority": priority})
+    return nodes if nodes else [{"goal": text.strip(), "context": "", "priority": 0}]
